# ============================================                                                  
# FORMEN POS - zmienne srodowiskowe    
# ============================================                                                  
# Skopiuj do .env i uzupelnij wartosci:              
#   cp .env.example .env               
#
# Auto-detekcja adaptera (config.ts):
#   VITE_SUPABASE_URL ustawiony -> adapter = supabase
#   VITE_API_URL ustawiony      -> adapter = rest
#   nic                         -> adapter = mock
#
# Mozesz tez wymusic adapter recznie:
#   VITE_DB_ADAPTER=mock | supabase | rest

# -- Srodowisko --
VITE_DB_ENV=development

# -- Supabase (DEV) --
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -- REST API (PROD - Hetzner VPS) --
# VITE_API_URL=https://pos.example.com